# Example .env — copy this file to `.env` and fill in real values.
# `.env` is gitignored; never commit secrets.

# Postgres (Neon) connection string
DATABASE_URL=

# Used by some scripts as a fallback set
PGDATABASE=
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=

# Express session secret — use a long random string in production
SESSION_SECRET=

# Server port (default 5000)
PORT=5000

# Anthropic Claude API
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Hetzner S3-compatible object storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# MCP server — bearer token for Cowork connections.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
MCP_BEARER_TOKEN=
# Identifier written into the audit log for this agent (e.g. "cowork", "claude-code")
MCP_AGENT_ID=cowork
